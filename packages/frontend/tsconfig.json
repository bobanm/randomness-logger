{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "paths": { "@/*": ["./src/*"] },
    "jsx": "preserve"
  },
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "vite.config.*", "src/app.d.ts"]
}
